# ReRoom environment variables
# Copy this file to .env and fill in your Azure credentials.

# Azure AI Foundry (GPT-4o vision analysis)
AZURE_AI_FOUNDRY_ENDPOINT=https://your-endpoint.services.ai.azure.com/
AZURE_AI_FOUNDRY_API_KEY=your-foundry-api-key

# Azure OpenAI (image generation with GPT-Image-1 or DALL-E 3)
AZURE_OPENAI_ENDPOINT=https://your-openai-endpoint.openai.azure.com/
AZURE_OPENAI_API_KEY=your-openai-api-key

# Optional: Override default model names
# REROOM_ANALYSIS_MODEL=gpt-4o
# REROOM_IMAGE_MODEL=gpt-image-1
# REROOM_IMAGE_SIZE=1024x1024
# REROOM_IMAGE_QUALITY=high
